# Pinned upstream dependency versions.
# Source this file in CI scripts, Makefiles, and local dev to get
# consistent version pins across GitLab, Bitbucket, and local builds.
#
# Usage:
#   source PINNED_PIPELINE_VERSIONS
#   make build BASE_CONTAINERS_UPSTREAM_TAG=$BASE_CONTAINERS_UPSTREAM_TAG

# Base-containers upstream image tag (the FROM images cicd-pipelines builds on)
BASE_CONTAINERS_UPSTREAM_TAG=0.4.3

# CI/CD Pipelines runner image registry and tag (for gitflow/mirror adapters)
CICD_PIPELINES_REGISTRY=registry.gitlab.com/tomshley/brands/global/tware/tech/products/provisioning/cicd-pipelines
CICD_PIPELINES_RUNNER_TAG=0.5.3
